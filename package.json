{
  "name": "@webergency-utils/timer",
  "version": "0.0.1",
  "description": "",
  "author": "radixxko",
  "license": "MIT",
  "main": "dist/timer.js",
  "module": "dist/esm/timer.js",
  "types": "dist/timer.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/timer.d.ts",
        "default": "./dist/esm/timer.js"
      },
      "require": {
        "types": "./dist/timer.d.ts",
        "default": "./dist/timer.js"
      }
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "clean": "rm -rf dist package-lock.json node_modules && npm i",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "build": "tsc && tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "version": "git pull && npm run build && npm publish && npm run commit && git push",
    "commit": "node -e \"const version = require('./package.json').version.trim(); require('child_process').execSync('git add . && git commit -m \\\"Version ' + version + '\\\"');\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webergency-utils/timer.git"
  },
  "dependencies": {
    "@webergency-utils/heap": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
